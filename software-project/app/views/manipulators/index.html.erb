<% if false %>
<p style="color: green"><%= notice %></p>

<h1>Manipulators</h1>

<div id="manipulators">
  <% @manipulators.each do |manipulator| %>
    <%= render manipulator %>
    <p>
      <%= link_to "Show this manipulator", manipulator %>
    </p>
  <% end %>
</div>

<%= link_to "New manipulator", new_manipulator_path %>
<% end %>

<% content_for :manager_stylesheet do %>
<% end %>

<% content_for :manager_title do %>
  <li><a href="<%= manipulators_url %>" class="link title">操作者信息</a></li>
  <li><a href="<%= song_types_url %>" class="link">首页</a></li>
<% end %>

<% content_for :manager_search do %>
<% end %>

<% content_for :manager_table_title do %>
  <tr>
  <td></td>
  <td>名称</td>
  <td>类型</td>
  <td>性别</td>
  <td>操作</td>
  </tr>
<% end %>

<% content_for :manager_table_body do %>
  <% @manipulators.each do |manipulator| %>
    <tr id=<%= manipulator.id %>>
      <%= render manipulator %>
    </tr>
  <% end %>
<% end %>

<% content_for :manager_javascript do %>
  <%= javascript_include_tag "tip_delete" %>
<% end %>