<% content_for :main_stylesheet do %>
  <%= stylesheet_link_tag "song/header", "frame", "button", "form", "user_header", "song/song_info", "song/song_page" %>
<% end %>
<% content_for :main_title do %>
  <li><a href="<%= song_types_url %>" class="link">首页</a></li>
  <li><a href="<%= songs_url %>" class="link title">曲谱</a></li>
  <% if false %>
    
  <% if current_manipulatorid %>
    <li><a href="<%= my_page_manipulators_url(current_manipulatorid) %>" class="link">我的主页</a></li>
  <% end %>
  <% if current_manipulatorid and current_manipulatortype == "管理员" %>
    <li><a href="<%= reports_url %>" class="link">管理员界面</a></li>
  <% end %>
  <% end %>

<% end %>

<% content_for :main_body do %>
  <div class="body">

  <div class="main">
      <div class="song">
        <div class="song_info clearfix">
          <div class="song_avatar">
              <%= image_tag 'song/icon3.png' %>
          </div>

          <div class="song_content">
              <h1 class="song_name"><%= @song.名称 %></h1>
              <h5>演唱: <%= @song.演唱 %></h5>
              <h5>作词: <%= @song.作词 %></h5>
              <h5>作曲: <%= @song.作曲 %></h5>
              <% if false %>
                <h5>类型: <%= @song.song_type.名称 if @song.song_type %></h5>
                <h5>发布者: <%= @song.manipulator.名称 %></h5>
              <% end %>
              <div class="button">
                <%= link_to "修改", edit_song_path(@song), class: "change-button" %>
                <%= button_to "删除", @song, method: :delete, class: "delete-button" %>
              </div>
          </div>
        </div>
      </div>

      <div class="song">
        <h3 class="song_header">
          <%= image_tag 'song/icon4.png' %>
          <span>曲谱</span>
        </h3>

        <%= form_with(model:[@song, Picture.new], remote: true, id: "file-upload") do |f| %>
          <div style="padding-bottom:10px;">
            <%= f.label :图片, style: "display: block" %>
            <%= f.file_field :图片, :multiple => true %>
          </div>
          <div style="padding-bottom:10px;">
          <%= f.submit "上传图片", class:"upload-button" %>
        </div>
        <% end %>

        <%= render :partial => @song.pictures %>  
      </div>

  </div>

  </div>
<% end %>

<% content_for :main_javascript do %>
  <%= javascript_include_tag "tip_delete", "tip_upload" %>
<% end %>